local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Cấu hình tốc độ quét (Giảm xuống nếu bị lag)
local WAIT_TIME = 0

print("QuacHub: Auto Collect Started (No UI/No AFK)")

task.spawn(function()
    while true do
        local success, err = pcall(function()
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            -- Xác định vùng quét: Workspace.orbs
            local targetFolder = workspace:FindFirstChild("orbs")
            
            if hrp and targetFolder then
                -- Quét sâu tất cả mọi thứ bên trong folder orbs
                local descendants = targetFolder:GetDescendants()
                
                for i = 1, #descendants do
                    local obj = descendants[i]
                    
                    -- Tìm trực tiếp đối tượng TouchTransmitter (TouchInterest)
                    if obj:IsA("TouchTransmitter") then
                        local parentPart = obj.Parent
                        
                        -- Kiểm tra nếu cha của nó là một Part hợp lệ
                        if parentPart and parentPart:IsA("BasePart") then
                            firetouchinterest(hrp, parentPart, 0) -- Chạm
                            firetouchinterest(hrp, parentPart, 1) -- Thả
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn("Lỗi quét Orb: " .. err)
        end
        
        task.wait(WAIT_TIME)
    end
end)
