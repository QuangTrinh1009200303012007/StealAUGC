sg.Name = "RbxNayap_Extreme_Overlay"
sg.ResetOnSpawn = false
sg.DisplayOrder = 2147483647
sg.IgnoreGuiInset = true

local function ForceOnTop()
    for _, child in ipairs(CoreGui:GetChildren()) do
        if child:IsA("ScreenGui") and child ~= sg then
            if child.DisplayOrder >= sg.DisplayOrder then
                child.DisplayOrder = 2147483646
            end
        end
    end
    sg.DisplayOrder = 2147483647
    
    local p = CoreGui:FindFirstChild("PurchasePrompt") or CoreGui:FindFirstChild("RobloxGui") or CoreGui
    if sg.Parent ~= p then
        sg.Parent = p
    end
end
