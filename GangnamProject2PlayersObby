local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local lp = Players.LocalPlayer

-- Rejoin khi bị kick hoặc lỗi
GuiService.ErrorMessageChanged:Connect(function()
    task.wait()
    TeleportService:Teleport(game.PlaceId, lp)
end)

--================ LOGIC SERVER HOP =================--
local function ServerHop()
    local placeId = game.PlaceId
    local success, servers = pcall(function()
        return HttpService:JSONDecode(game:HttpGetAsync("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"))
    end)

    if success and servers and servers.data then
        for _, server in pairs(servers.data) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                TeleportService:TeleportToPlaceInstance(placeId, server.id, lp)
                return
            end
        end
    end
    TeleportService:Teleport(placeId, lp) -- Fallback
end

--================ AUTO FARM + AUTO HOP =================--
task.spawn(function()
    task.wait() 
    
    local diamondFolder = workspace:WaitForChild("CoopMap", 10):WaitForChild("DiamondNotes", 10)
    -- Lấy TextLabel chứa số kim cương
    local diamondLabel = lp:WaitForChild("PlayerGui"):WaitForChild("HUD"):WaitForChild("DiamondCount"):WaitForChild("DiamondQtHolder"):GetChildren()[2]
    
    -- Hàm lấy giá trị số từ TextLabel
    local function getDiamondValue()
        return tonumber(diamondLabel.ContentText) or tonumber(diamondLabel.Text) or 0
    end

    while true do
        local notes = diamondFolder:GetChildren()
        
        if #notes > 0 then
            local startValue = getDiamondValue()
            
            -- Thực hiện farm toàn bộ note hiện có
            for _, note in pairs(notes) do
                local touchPart = note:FindFirstChild("TouchDetector")
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                
                if touchPart and hrp then
                    firetouchinterest(hrp, touchPart, 0)
                    task.wait() -- Giữ nguyên delay gốc
                    firetouchinterest(hrp, touchPart, 1)
                end
            end

            -- Đợi số bắt đầu tăng và sau đó dừng hẳn mới hop
            local lastValue = startValue
            local lastChangeTick = tick()
            local hasIncreased = false

            while true do
                task.wait(0.2) -- Check liên tục mỗi 0.2s
                local currentValue = getDiamondValue()

                if currentValue > lastValue then
                    hasIncreased = true
                    lastValue = currentValue
                    lastChangeTick = tick() -- Reset thời gian mỗi khi số tăng
                elseif hasIncreased and (tick() - lastChangeTick > 1) then
                    -- Nếu đã từng tăng và hiện tại đã đứng yên quá 1.5 giây
                    print("Kim cương đã dừng tăng. Đang đổi server...")
                    ServerHop()
                    return -- Thoát task
                elseif not hasIncreased and (tick() - lastChangeTick > 1) then
                    -- Backup: Nếu sau 5 giây fire mà số không hề tăng (lỗi hoặc lag), vẫn hop
                    ServerHop()
                    return
                end
            end
        else
            -- Nếu không có note nào ngay từ đầu
            print("Không có vật phẩm. Đang đổi server...")
            ServerHop()
            break
        end
        task.wait()
    end
end)
