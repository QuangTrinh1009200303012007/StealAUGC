    end
    loopBtn.MouseButton1Click:Connect(function() getgenv().Config.TeleportLoop = not getgenv().Config.TeleportLoop; SaveConfig(); UpdLoop() end)
    UpdLoop()

    local saveBtn = Instance.new("TextButton", tpRow)
    saveBtn.Position = UDim2.new(0.4, 0, 0, 0)
    saveBtn.Size = UDim2.new(0.4, -5, 1, 0)
    saveBtn.BackgroundColor3 = Color3.fromRGB(52, 152, 219)
    saveBtn.Text = "SAVE POS"
    saveBtn.Font = Enum.Font.GothamBold
    saveBtn.TextSize = 10
