    tpBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    tpBox.Text = tostring(getgenv().Config.TeleportDelay)
    tpBox.FocusLost:Connect(function() getgenv().Config.TeleportDelay = tonumber(tpBox.Text) or 0.5; SaveConfig() end)

    -- 3. HÀNG AUTO HOP VÀ AUTO REJOIN TIMER
