local function handleCharacterLogic()
    local char = lp.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if getgenv().Config.AntiStuck and hum.Sit then hum.Jump = true end
        if getgenv().Config.AutoJump and hum.FloorMaterial ~= Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        if getgenv().Config.AntiStuck then
            local state = hum:GetState()
            if state == Enum.HumanoidStateType.FallingDown or state == Enum.HumanoidStateType.PlatformStanding then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
        end
        if getgenv().Config.NoClip then
            for _, part in pairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
        end
        if getgenv().Config.Fly and hrp then
            local v = hrp:FindFirstChild("S_Fly") or Instance.new("BodyVelocity", hrp)
            v.Name = "S_Fly"; v.Velocity = Vector3.new(0, 0, 0); v.MaxForce = Vector3.new(0, 9e9, 0)
        elseif hrp and hrp:FindFirstChild("S_Fly") then hrp.S_Fly:Destroy() end
    end
end

if _G.MainLoop then _G.MainLoop:Disconnect() end
_G.MainLoop = RunService.RenderStepped:Connect(handleCharacterLogic)

task.spawn(function()
    while true do
        if getgenv().Config.TeleportLoop and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
