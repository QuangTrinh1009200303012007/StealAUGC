if getgenv().AfkForFreeUGC_bwush then return end
getgenv().AfkForFreeUGC_bwush = true

--===[ GUI DEBUG ĐẾM NGƯỢC ]===--
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DebugCountdown"
screenGui.ResetOnSpawn = false
screenGui.Parent = game:GetService("CoreGui")

local debugLabel = Instance.new("TextLabel")
debugLabel.Size = UDim2.new(0, 400, 0, 50)
debugLabel.Position = UDim2.new(0.5, -200, 0.5, -25)
debugLabel.BackgroundColor3 = Color3.new(0, 0, 0)
debugLabel.BackgroundTransparency = 0.5
debugLabel.TextColor3 = Color3.new(1, 1, 0)
debugLabel.TextScaled = true
debugLabel.Font = Enum.Font.Code
debugLabel.Parent = screenGui

--===[ QueueOnTeleport Loader ]===--
local QueueOnTeleport = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
local SCRIPT_URL = "https://raw.githubusercontent.com/QuangTrinh1009200303012007/RobloxUGC_Scripts/refs/heads/main/AfkForFreeUGC_bwush"

-- Biến kiểm soát việc có cho phép Rejoin hay không
local allowRejoin = true 

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local player = game.Players.LocalPlayer
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")

-- 1. Hàm kiểm tra số lượng người và quyết định có Rejoin hay không
local function CheckServerSecurity()
    if #Players:GetPlayers() >= 2 then
        allowRejoin = false -- Vô hiệu hóa tính năng tự động quay lại
        player:Kick("\n[BẢO MẬT CAO]\nPhát hiện server có " .. #Players:GetPlayers() .. " người.\nDừng Rejoin để bảo vệ tài khoản.")
    end
end

-- Chạy kiểm tra ngay lập tức và khi có người mới vào
CheckServerSecurity()
Players.PlayerAdded:Connect(CheckServerSecurity)

-- 2. Thực hiện Tween thay vì Teleport (Vận tốc 500)
task.spawn(function()
    local targetPos = Vector3.new(741, 256, -329)
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    local distance = (hrp.Position - targetPos).Magnitude
    local duration = distance / 500

    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
    
    tween:Play()
    tween.Completed:Wait()
end)

-- 3. Logic Rejoin
local function RejoinLogic()
    -- Chỉ thực hiện Rejoin nếu biến allowRejoin vẫn là true
    if not allowRejoin then 
        print("Rejoin bị chặn do phát hiện server không an toàn.")
        return 
    end

    if game.PrivateServerId ~= "" then
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

-- Tự động gọi Rejoin khi mất kết nối hoặc bị Kick
GuiService.ErrorMessageChanged:Connect(function()
    if allowRejoin then
        task.wait(0.1)
        RejoinLogic()
    end
end)

-- 4. THỰC HIỆN KICK ĐỂ REJOIN VỚI ĐẾM NGƯỢC DEBUG
local timeLeft = 10.5
while timeLeft > 0 do
    debugLabel.Text = string.format("REJOIN TRONG: %.1fS", timeLeft)
    task.wait(0.1)
    timeLeft = timeLeft - 0.1
end

if allowRejoin then
    player:Kick("Đang Rejoin về Server Riêng để kích hoạt script...")
end
