-- === LOGIC NÚT 1: MYSTERY BUTTON (GIỮ NGUYÊN GỐC) ===
local function startMysteryFarm()
    while mysteryActive do
        for i = 1, 999 do
            task.spawn(function()
                local character = player.Character
                if not character then return end
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if not rootPart then return end

                -- --- ĐOẠN GỐC CỦA BẠN ---
                local buttons = {}
                for _, m in ipairs(workspace:GetChildren()) do
                    if m.Name == "MysteryButton_Round" then
                        local p = m:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if p then table.insert(buttons, p) end
                    end
                end

                for _, prompt in ipairs(buttons) do
                    if not mysteryActive then break end -- Dừng nếu tắt nút
                    if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then break end
                    if prompt and prompt.Parent and prompt.Enabled then
                        rootPart.CFrame = prompt.Parent.CFrame
                        task.wait(0.1) 
                        fireproximityprompt(prompt)
                        local checkStartTime = tick()
                        repeat
                            task.wait() 
                            if tick() - checkStartTime > 10 then break end 
                        until not prompt or not prompt.Parent or not prompt.Enabled or not prompt:IsDescendantOf(game)
                        task.wait(0.01) 
                    end
                end
                -- --- HẾT ĐOẠN GỐC ---
            end)
        end
        task.wait(0.1)
    end
end

-- === LOGIC NÚT 2: CLAIM UGC (TỌA ĐỘ 11, 71, -196) ===
local function startClaimUGC()
    while ugcActive do
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if rootPart then
            -- Fire liên tục (Dùng for 1,4 để tăng tốc độ chiếm quyền)
            for i = 1, 4 do
                task.spawn(function()
                    local path = game:GetService("Workspace"):FindFirstChild("UGCLimted")
                    if path then
                        local prompt = path["UGC"]["Proximitys"]["UGCBuy"]["ProximityPrompt"]
                        if prompt then
                            fireproximityprompt(prompt)
                        end
                    end
                end)
            end
        end
        task.wait(1) -- Delay 1s như yêu cầu
    end
end

