if getgenv().AfkForFreeUGC_bwush then return end
getgenv().AfkForFreeUGC_bwush = true

-- Đợi game load hoàn toàn
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Đợi Model nhân vật load kỹ để tránh lỗi game pause khi di chuyển quá nhanh
if not player.Character then
    player.CharacterAdded:Wait()
end
local character = player.Character or player.CharacterAdded:Wait()
character:WaitForChild("HumanoidRootPart")
character:WaitForChild("Humanoid")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DebugCountdown"
screenGui.ResetOnSpawn = false
screenGui.Parent = game:GetService("CoreGui")

local debugLabel = Instance.new("TextLabel")
debugLabel.Size = UDim2.new(0, 400, 0, 50)
debugLabel.Position = UDim2.new(0.5, -200, 0.5, -25)
debugLabel.BackgroundColor3 = Color3.new(0, 0, 0)
debugLabel.BackgroundTransparency = 0.5
debugLabel.TextColor3 = Color3.new(1, 1, 0)
debugLabel.TextScaled = true
debugLabel.Font = Enum.Font.Code
debugLabel.Parent = screenGui

local QueueOnTeleport = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
local SCRIPT_URL = "https://raw.githubusercontent.com/Hi2983488r93993/RobloxUGC_Scripts/refs/heads/main/AfkForFreeUGC10_bwush10"
local allowRejoin = true 

pcall(function()
    if QueueOnTeleport then
        QueueOnTeleport("loadstring(game:HttpGet('"..SCRIPT_URL.."'))()")
    end
end)

local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")

local function CheckServerSecurity()
    if #Players:GetPlayers() >= 2 then
        allowRejoin = false 
        player:Kick("\nServer có " .. #Players:GetPlayers() .. " người! Vô server riêng dùm coi 😡")
    end
end

CheckServerSecurity()
Players.PlayerAdded:Connect(CheckServerSecurity)

-- Logic theo dõi nhân vật chết thì Kick
task.spawn(function()
    while task.wait(1) do
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.Died:Connect(function()
                    if allowRejoin then
                        player:Kick("Nhân vật đã chết! Đang thực hiện Rejoin để tránh lỗi treo máy...")
                    end
                end)
                -- Break vòng lặp sau khi đã kết nối sự kiện Died cho nhân vật hiện tại
                -- Sự kiện CharacterAdded sẽ lo phần nhân vật mới nếu có
                break 
            end
        end
    end
end)

-- Cập nhật Text hiển thị (Chỉ hiển thị điểm, không thực hiện logic check kick điểm)
task.spawn(function()
    local leaderstats = player:WaitForChild("leaderstats", 30)
    if leaderstats then
        local pointsValue = leaderstats:WaitForChild("Points", 30)
        if pointsValue then
            local lastPoints = pointsValue.Value
            while task.wait(1) do
                local currentPoints = pointsValue.Value
                local difference = currentPoints - lastPoints
                debugLabel.Text = "Points: " .. tostring(currentPoints) .. " (+" .. tostring(difference) .. ")"
                lastPoints = currentPoints
            end
        end
    end
end)

-- Logic di chuyển chính
task.spawn(function()
    if not allowRejoin then return end
    
    while true do
        local character = player.Character or player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")
        
        -- Kiểm tra Stage 10
        local stage10 = workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10")

        if stage10 then
            -- ĐỢI CHO ĐẾN KHI STAGE 10 THỰC SỰ TỒN TẠI TRONG WORKSPACE VÀ CÓ VỊ TRÍ
            repeat task.wait(0.5) until workspace:FindFirstChild("obby") and workspace.obby.Stages:FindFirstChild("Stage 10")
            
            -- LOGIC STAGE 10: Tốc độ 500
            local distance = (hrp.Position - stage10.Position).Magnitude
            local tween = TweenService:Create(hrp, TweenInfo.new(distance / 700, Enum.EasingStyle.Linear), {CFrame = stage10.CFrame})
            tween:Play()
            tween.Completed:Wait()
        else
            -- LOGIC TỌA ĐỘ PHỤ: Tốc độ 200
            local targetPos = CFrame.new(41338, -71, -21)
            
            -- KIỂM TRA XEM CÓ PROXIMITYPROMPT NÀO Ở GẦN TỌA ĐỘ MỤC TIÊU KHÔNG TRƯỚC KHI BAY
            local function IsTargetAreaLoaded()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        local p = obj.Parent:IsA("BasePart") and obj.Parent.Position or obj.Parent:GetPivot().Position
                        if (p - targetPos.Position).Magnitude < 100 then
                            return true
                        end
                    end
                end
                return false
            end

            -- Đợi cho đến khi phát hiện thấy object ở vùng tọa độ phụ hoặc Stage 10 xuất hiện
            repeat 
                task.wait(1) 
            until IsTargetAreaLoaded() or (workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10"))

            -- Nếu Stage 10 xuất hiện trong lúc đợi thì quay lại đầu vòng lặp
            if not (workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10")) then
                local distance = (hrp.Position - targetPos.Position).Magnitude
                local tween = TweenService:Create(hrp, TweenInfo.new(distance / 200, Enum.EasingStyle.Linear), {CFrame = targetPos})
                tween:Play()
                
                -- Trong khi đang bay tới tọa độ phụ, vẫn phải check xem Stage 10 có xuất hiện đột ngột không
                local reached = false
                local connection
                connection = tween.Completed:Connect(function()
                    reached = true
                    connection:Disconnect()
                end)

                -- Vòng lặp nhỏ để vừa bay vừa check Stage 10
                while not reached do
                    if workspace:FindFirstChild("obby") and workspace.obby:FindFirstChild("Stages") and workspace.obby.Stages:FindFirstChild("Stage 10") then
                        tween:Cancel() -- Hủy ngay lập tức nếu thấy Stage 10
                        break
                    end
                    task.wait(0.1)
                end

                -- Nếu đã tới đích (tọa độ phụ) và không có Stage 10 thì mới bấm nút
                if reached then
                    local g = nil
                    local h = 30
                    for i, j in pairs(workspace:GetDescendants()) do
                        if j:IsA("ProximityPrompt") then
                            local k = (hrp.Position - (j.Parent:IsA("BasePart") and j.Parent.Position or j.Parent:GetPivot().Position)).Magnitude
                            if k < h then
                                h = k
                                g = j
                            end
                        end
                    end
                    if g then fireproximityprompt(g) end
                end
            end
        end
        task.wait(0.1)
    end
end)

local function RejoinLogic()
    if not allowRejoin then return end
    if game.PrivateServerId ~= "" then
        TeleportService:TeleportToPrivateServer(game.PlaceId, game.PrivateServerId, {player})
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

GuiService.ErrorMessageChanged:Connect(function()
    if allowRejoin then
        task.wait(0.1)
        RejoinLogic()
    end
end)
